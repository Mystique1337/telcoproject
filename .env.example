# =============================================================================
# Naija Persona Agent — Environment Variables
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.
# =============================================================================

# --- LLM API keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- NVIDIA NeMo / NIM (for synthetic data generation via Nemotron) ---
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Recommended NeMo model for synthetic generation:
#   nvidia/llama-3.1-nemotron-70b-instruct
#   nvidia/llama-3.3-nemotron-super-49b-v1
#   meta/llama-3.1-70b-instruct

# --- HuggingFace token (for model downloads + uploads) ---
HF_TOKEN=hf_...

# --- Weights & Biases (experiment tracking) ---
WANDB_API_KEY=
WANDB_PROJECT=naija-persona-agent

# --- LangSmith (optional, agent tracing) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=naija-persona-agent
LANGCHAIN_TRACING_V2=false

# --- Service endpoints (inside docker compose network) ---
OLLAMA_URL=http://localhost:11434
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Model defaults ---
TASK1_BACKBONE=anthropic:claude-sonnet-4-20250514
TASK1_FALLBACK=anthropic:claude-sonnet-4-20250514
TASK2_RERANKER=anthropic:claude-sonnet-4-20250514
PERSONA_EXTRACTOR=anthropic:claude-sonnet-4-20250514
EMBEDDING_MODEL=openai:text-embedding-3-small

# Once NaijaReviewer-8B is fine-tuned and pulled into Ollama, switch:
# TASK1_BACKBONE=ollama:naija-reviewer-8b

# --- Feature flags ---
ENABLE_BUSINESS_DEMO=false
ENABLE_STREAMING=true
ENABLE_REASONING_TRACE=true

# --- Storage paths ---
SQLITE_PATH=data/personas.db
CHROMA_PATH=data/chroma_db

# --- Logging ---
LOG_LEVEL=INFO

# --- App ---
APP_NAME=naija-persona-agent
APP_VERSION=0.1.0
