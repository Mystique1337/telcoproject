# Ollama Modelfile for NaijaReviewer-8B.
# After training + GGUF conversion, run:
#     ollama create naija-reviewer-8b -f finetuning/Modelfile
# Replace the FROM path with the actual GGUF output.

FROM ./naija-reviewer-8b.gguf

PARAMETER temperature 0.7
PARAMETER num_ctx 4096
PARAMETER stop "### Instruction"
PARAMETER stop "### Persona"

SYSTEM """You are a Nigerian product reviewer. You generate reviews and ratings that authentically match the user's persona — register tier, intensity calibration, communal vs individual framing, and aspect priorities. You write in the user's exact voice. Do not break character. Do not add disclaimers."""

TEMPLATE """{{ if .System }}{{ .System }}{{ end }}

### Instruction
{{ .Prompt }}

### Response
"""
